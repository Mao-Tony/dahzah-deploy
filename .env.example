# ==================== 应用配置 ====================
APP_ENV=production
DEBUG=false
SECRET_KEY=your-secret-key-change-this-in-production

# ==================== 数据库配置 ====================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dazah
DB_PORT=5432

# ==================== Redis配置 ====================
REDIS_PORT=6379

# ==================== 前端 API 配置 ====================
# Docker 容器内通信地址
NEXT_PUBLIC_API_URL=http://backend:8000/api/v1
# 如需外网访问，改为服务器 IP 或域名，例如:
# NEXT_PUBLIC_API_URL=http://你的服务器IP:8000/api/v1

# ==================== AI 服务配置 (MiniMax) ====================
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_BASE_URL=https://api.minimax.chat
MINIMAX_MODEL=abab6.5s-chat

# ==================== 飞书配置 (可选) ====================
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_BOT_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxx

# ==================== 日志配置 ====================
AUDIT_RETENTION_DAYS=7
